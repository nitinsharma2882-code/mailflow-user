{
  "name": "mailflow",
  "version": "1.0.0",
  "description": "Bulk email marketing desktop application",
  "main": "electron/main.js",
  "author": {
    "name": "Your Name",
    "email": "you@yourdomain.com"
  },
  "scripts": {
    "build:secure": "node scripts/build-secure.js",
    "dev": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "npm run build:react && npm run build:electron",
    "build:react": "vite build",
    "build:electron": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "release": "npm run build:react && electron-builder --publish always",
    "lint": "eslint src --ext .js,.jsx",
    "migrate": "node database/migrate.js",
    "fix-sqlite": "node scripts/fix-sqlite.js"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.529.1",
    "@sendgrid/mail": "^8.1.1",
    "axios": "^1.6.7",
    "better-sqlite3": "^9.4.3",
    "bull": "^4.12.2",
    "csv-parser": "^3.0.0",
    "electron-updater": "^6.1.8",
    "form-data": "^4.0.0",
    "mailgun.js": "^10.2.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.1",
    "winston": "^3.12.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "javascript-obfuscator": "^5.4.1",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mailflow.app",
    "productName": "Mailflow",
    "copyright": "Copyright 2026 Your Name",
    "directories": {
      "output": "dist-electron",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "database/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md}",
      "!node_modules/*/{test,__tests__,tests,example,examples}",
      "!node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp}",
      "!**/{.DS_Store,.git,.hg,.svn,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs}"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "nitinsharma2882-code",
      "repo": "mailflow-user"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mailflow",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icons",
      "category": "Network"
    }
  }
}
